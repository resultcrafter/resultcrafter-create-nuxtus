{
  "name": "create-nuxtus",
  "description": "npx command for generating a new Nuxtus boilerplate website.",
  "version": "2.1.7",
  "exports": "./build/src/main.js",
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=8.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuxtus/create-nuxtus.git"
  },
  "keywords": [
    "Directus",
    "Nuxt",
    "boilerplate",
    "Tailwind",
    "Tailwindcss"
  ],
  "author": "Craig Harman",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nuxtus/create-nuxtus/issues"
  },
  "homepage": "https://github.com/nuxtus/create-nuxtus#readme",
  "scripts": {
    "start": "node build/src/main.js",
    "clean": "rimraf coverage build tmp",
    "prebuild": "npm run lint",
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "build:release": "npm run clean && tsc -p tsconfig.release.json",
    "lint": "eslint .",
    "test": "jest --coverage",
    "prettier": "prettier --config .prettierrc --write .",
    "test:watch": "jest --watch"
  },
  "bin": {
    "create-nuxtus": "./build/src/main.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "chalk": "^5.0.1",
    "child_process": "^1.0.2",
    "command-exists": "^1.2.9",
    "figlet": "^1.5.2",
    "inquirer": "^13.0.0",
    "joi": "^18.0.0",
    "liquidjs": "^10.0.0",
    "nanoid": "^5.0.0",
    "nunjucks": "^3.2.3",
    "ora": "^9.0.0",
    "rimraf": "^6.0.0",
    "tslib": "~2.8.0",
    "uuid": "^13.0.0"
  },
  "release": {
    "branches": "main",
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "type": "revert",
              "release": "patch"
            },
            {
              "type": "refactor",
              "release": "minor"
            }
          ]
        }
      ],
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogTitle": "Changelog"
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  },
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/jest": "29.5.14",
    "@types/node": "24.12.0",
    "eslint": "10.0.3",
    "@eslint/js": "10.0.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.0",
    "typescript-eslint": "8.57.0",
    "jest": "29.7.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "semantic-release": "25.0.3",
    "ts-jest": "29.4.6",
    "tsutils": "3.21.0",
    "typescript": "5.9.3"
  },
  "volta": {
    "node": "24.14.0"
  }
}
